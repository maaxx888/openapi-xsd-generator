{
  "openapi": "3.0.0",
  "info": {
    "title": "Constraints API",
    "version": "1.0.0",
    "description": "Tests JSON Schema constraints and combinators"
  },
  "paths": {
    "/organisations/{orgId}": {
      "get": {
        "operationId": "getOrganisation",
        "parameters": [
          {
            "name": "orgId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^ORG-\\d{6}$",
              "minLength": 10,
              "maxLength": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationSuccessResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/organisations": {
      "post": {
        "operationId": "createOrganisation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrganisationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationSuccessResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrganisationCore": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Organisation name"
          },
          "employeeCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100000
          }
        },
        "required": ["name"]
      },
      "OrganisationMeta": {
        "type": "object",
        "properties": {
          "sector": {
            "type": "string",
            "enum": ["PUBLIC", "PRIVATE", "NON_PROFIT"]
          },
          "verified": {
            "type": "boolean"
          }
        }
      },
      "OrganisationDetails": {
        "allOf": [
          { "$ref": "#/components/schemas/OrganisationCore" },
          { "$ref": "#/components/schemas/OrganisationMeta" }
        ],
        "type": "object",
        "properties": {
          "registrationNumber": {
            "type": "string",
            "pattern": "^[0-9]{10}$",
            "description": "Belgian enterprise number"
          }
        },
        "required": ["registrationNumber"]
      },
      "OrganisationSuccessResponse": {
        "type": "object",
        "required": ["status"],
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string",
            "enum": ["SUCCESS", "FAILED"]
          },
          "organisation": {
            "type": "object",
            "properties": {
              "organisationId": {
                "type": "string",
                "pattern": "^ORG-\\d{6}$"
              },
              "details": {
                "$ref": "#/components/schemas/OrganisationDetails"
              },
              "tags": {
                "type": "array",
                "minItems": 1,
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "maxLength": 32
                }
              }
            },
            "required": ["organisationId", "details"]
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "OrganisationErrorResponse": {
        "type": "object",
        "required": ["status", "errors"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["FAILED"]
          },
          "correlationId": {
            "type": "string",
            "format": "uuid",
            "description": "Only present on errors"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z_]{3,32}$"
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "details": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      },
      "CreateOrganisationRequest": {
        "oneOf": [
          {
            "type": "object",
            "required": ["name", "registrationNumber"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "registrationNumber": {
                "type": "string",
                "pattern": "^[0-9]{10}$"
              }
            }
          },
          {
            "type": "object",
            "required": ["name", "foreignId"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "foreignId": {
                "type": "string",
                "pattern": "^[A-Z]{2}-[A-Z0-9]{8}$"
              }
            }
          }
        ]
      }
    }
  }
}
