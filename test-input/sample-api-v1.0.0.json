{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Sample API with POST",
    "description": "API with both GET and POST operations"
  },
  "tags": [
    {
      "name": "Resources",
      "description": "Resource operations"
    }
  ],
  "servers": [
    {
      "url": "https://api.example.com/v1",
      "description": "Production"
    }
  ],
  "paths": {
    "/items": {
      "post": {
        "tags": ["Resources"],
        "summary": "Create an item",
        "operationId": "createItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItemRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/ItemCreatedResponse"
          }
        }
      }
    },
    "/items/{itemId}": {
      "get": {
        "tags": ["Resources"],
        "summary": "Get item by ID",
        "operationId": "getItemById",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/ItemResponse"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateItemRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The item name (required)"
          },
          "description": {
            "type": "string",
            "description": "Optional item description"
          },
          "price": {
            "type": "number",
            "description": "Item price in EUR (required)"
          }
        },
        "required": ["name", "price"],
        "additionalProperties": false
      },
      "ItemResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["SUCCESS", "FAILED"],
            "description": "Operation status"
          },
          "item": {
            "type": "object",
            "description": "Item details (present on success)",
            "properties": {
              "itemId": {
                "type": "string",
                "description": "Unique item identifier"
              },
              "name": {
                "type": "string",
                "description": "Item name"
              },
              "description": {
                "type": "string",
                "description": "Item description"
              },
              "price": {
                "type": "number",
                "description": "Item price in EUR"
              }
            },
            "required": ["itemId", "name", "price"],
            "additionalProperties": false
          },
          "errors": {
            "type": "array",
            "description": "Error details (present on failure)",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string",
                  "description": "Error code"
                },
                "message": {
                  "type": "string",
                  "description": "Error message"
                }
              },
              "required": ["code", "message"]
            }
          }
        },
        "required": ["status"],
        "additionalProperties": false
      }
    },
    "responses": {
      "ItemResponse": {
        "description": "Item response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ItemResponse"
            }
          }
        }
      },
      "ItemCreatedResponse": {
        "description": "Item created",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ItemResponse"
            }
          }
        }
      }
    }
  }
}
